{
  "expo": {
    "name": "Movie-App",
    "slug": "Movie-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Images/MainLogo.png",
    "scheme": "movieapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/Images/MainLogo.png",
        "backgroundImage": "./assets/Images/MainLogo.png",
        "monochromeImage": "./assets/Images/MainLogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.imranwali.movieapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Images/MainLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Images/MainLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "721483fd-593f-4af0-af2a-480a8fa1a5bf"
      }
    }
  }
}
