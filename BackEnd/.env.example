# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key                  # used to verify incoming user JWTs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # privileged DB/storage writes — NEVER expose to any client

# TMDB
TMDB_API_KEY=your-tmdb-api-key

# Optional — only needed if you extend ai_service.py to use OpenAI embeddings
OPENAI_API_KEY=your-openai-api-key

# App
FLASK_ENV=production
PORT=5000
CORS_ORIGINS=*                                   # comma-separated in production, e.g. https://yourapp.com

# sentence-transformers model, downloaded/cached on first run
EMBEDDING_MODEL=all-MiniLM-L6-v2